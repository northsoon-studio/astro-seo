# Dev-only type declarations — the Astro language server in the user's project
# already injects Fragment, Astro, and other globals automatically.
# Shipping these files can cause duplicate-identifier conflicts in user projects.
src/astro.d.ts
src/env.d.ts

# Astro config — only needed for language server support during library development
astro.config.mjs
